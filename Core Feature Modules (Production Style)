/* =========================================================
   🐙 4. GITHUB IMPORT / EXPORT SYSTEM
========================================================= */

/* Unicode-safe base64 */
const encodeBase64 = (str: string) =>
  btoa(unescape(encodeURIComponent(str)));

export const importGitHubFile = async (url: string) => {
  const rawUrl = url
    .replace("github.com", "raw.githubusercontent.com")
    .replace("/blob/", "/");

  const res = await fetch(rawUrl);
  if (!res.ok) throw new Error("Failed to fetch file");

  return await res.text();
};

export const pushToGitHub = async (
  token: string,
  repo: string,
  filePath: string,
  content: string
) => {
  const apiUrl = `https://api.github.com/repos/${repo}/contents/${filePath}`;

  const headers = {
    Authorization: `token ${token}`,
    "Content-Type": "application/json",
    Accept: "application/vnd.github+json",
  };

  let sha;

  try {
    const getRes = await fetch(apiUrl, { headers });

    if (getRes.ok) {
      const data = await getRes.json();
      sha = data.sha;
    }
  } catch {}

  const res = await fetch(apiUrl, {
    method: "PUT",
    headers,
    body: JSON.stringify({
      message: "Update from VERION IDE",
      content: encodeBase64(content),
      sha,
    }),
  });

  if (!res.ok) {
    throw new Error("GitHub push failed");
  }
};

/* =========================================================
   📱 5. SPLIT SCREEN + SWIPE UI CONTROLLER
========================================================= */

type LayoutMode = "editor" | "preview" | "split";

export const useLayoutMode = () => {
  const setMode = (mode: LayoutMode) => {
    localStorage.setItem("layout_mode", mode);
  };

  const getMode = (): LayoutMode => {
    const mode = localStorage.getItem("layout_mode");
    return mode === "editor" || mode === "preview" ? mode : "split";
  };

  return { setMode, getMode };
};

/* Prevent duplicate listeners */
let swipeInitialized = false;

export const handleSwipe = (setMode: Function) => {
  if (swipeInitialized) return;
  swipeInitialized = true;

  let startX = 0;

  const onStart = (e: TouchEvent) => {
    startX = e.touches[0].clientX;
  };

  const onEnd = (e: TouchEvent) => {
    const endX = e.changedTouches[0].clientX;

    if (startX - endX > 50) setMode("preview");
    if (endX - startX > 50) setMode("editor");
  };

  window.addEventListener("touchstart", onStart);
  window.addEventListener("touchend", onEnd);
};

