import * as monaco from "monaco-editor";

export const keyboardButtons = [
  "{ }",
  "[ ]",
  "( )",
  "< >",
  "/",
  "Tab",
  "=>",
  ";",
];

export const insertAtCursor = (editor: any, text: string) => {
  if (!editor) return;

  const position = editor.getPosition();
  if (!position) return;

  editor.executeEdits("", [
    {
      range: new monaco.Range(
        position.lineNumber,
        position.column,
        position.lineNumber,
        position.column
      ),
      text,
      forceMoveMarkers: true,
    },
  ]);

  editor.focus();
};

/* =========================================================
   📶 2. OFFLINE MODE + AUTO SYNC SYSTEM
========================================================= */

import { createClient } from "@supabase/supabase-js";

const supabase = createClient(
  process.env.SUPABASE_URL!,
  process.env.SUPABASE_ANON_KEY!
);

let isSyncing = false;

/* Safe JSON */
const safeParse = (data: string | null) => {
  try {
    return JSON.parse(data || "[]");
  } catch {
    return [];
  }
};

const getQueue = () => safeParse(localStorage.getItem("sync_queue"));

const setQueue = (queue: any[]) =>
  localStorage.setItem("sync_queue", JSON.stringify(queue));

export const saveOfflineProject = (project: any) => {
  localStorage.setItem(
    `offline_project_${project.id}`,
    JSON.stringify(project)
  );
};

export const getOfflineProject = (id: string) => {
  return safeParse(localStorage.getItem(`offline_project_${id}`));
};

export const queueSync = (data: any) => {
  const queue = getQueue();
  queue.push(data);
  setQueue(queue);
};

export const processSyncQueue = async () => {
  if (!navigator.onLine || isSyncing) return;

  isSyncing = true;

  const queue = getQueue();

  while (queue.length > 0) {
    const item = queue[0]; // don't shift yet

    try {
      const { error } = await supabase.from("projects").upsert(item);
      if (error) throw error;

      queue.shift(); // remove only on success
      setQueue(queue);
    } catch (err) {
      console.error("Sync failed, retry later:", err);
      break;
    }
  }

  isSyncing = false;
};

