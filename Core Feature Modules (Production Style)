/* =========================================================
   ⌨️ 1. DEVELOPER KEYBOARD SYSTEM
========================================================= */

export const keyboardButtons = [
  "{ }", "[ ]", "( )", "< >", "/", "Tab", "=>", ";",
];

export const insertAtCursor = (
  editor: monaco.editor.IStandaloneCodeEditor | null,
  text: string
) => {
  if (!editor) return;

  const position = editor.getPosition();
  if (!position) return;

  editor.executeEdits("", [
    {
      range: new monaco.Range(
        position.lineNumber,
        position.column,
        position.lineNumber,
        position.column
      ),
      text,
      forceMoveMarkers: true,
    },
  ]);

  editor.focus();
};

/* =========================================================
   📶 2. OFFLINE MODE + AUTO SYNC SYSTEM
========================================================= */

const SUPABASE_URL = process.env.SUPABASE_URL;
const SUPABASE_KEY = process.env.SUPABASE_ANON_KEY;

if (!SUPABASE_URL || !SUPABASE_KEY) {
  throw new Error("Missing Supabase environment variables");
}

const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

let isSyncing = false;

/* Safe JSON */
const safeParse = <T>(data: string | null, fallback: T): T => {
  try {
    return data ? JSON.parse(data) : fallback;
  } catch {
    return fallback;
  }
};

const getQueue = () => safeParse<any[]>(localStorage.getItem("sync_queue"), []);

const setQueue = (queue: any[]) => {
  localStorage.setItem("sync_queue", JSON.stringify(queue));
};

export const saveOfflineProject = (project: any) => {
  if (!project?.id) return;

  localStorage.setItem(
    `offline_project_${project.id}`,
    JSON.stringify(project)
  );
};

export const getOfflineProject = (id: string) => {
  return safeParse<any | null>(
    localStorage.getItem(`offline_project_${id}`),
    null
  );
};

export const queueSync = (data: any) => {
  if (!data || typeof data !== "object") return;

  const queue = getQueue();
  queue.push(data);
  setQueue(queue);
};

export const processSyncQueue = async () => {
  if (!navigator.onLine || isSyncing) return;

  isSyncing = true;

  const queue = getQueue();

  while (queue.length > 0) {
    const item = queue[0];

    try {
      const { error } = await supabase.from("projects").upsert(item);

      if (error) throw error;

      queue.shift();
      setQueue(queue);

    } catch (err) {
      console.error("Sync failed, dropping bad item:", err);

      // 🔥 Drop bad item instead of blocking queue forever
      queue.shift();
      setQueue(queue);
    }
  }

  isSyncing = false;
};

