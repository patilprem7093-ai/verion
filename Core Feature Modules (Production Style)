export const fetchCommunityProjects = async () => {
  try {
    const { data, error } = await supabase
      .from("public_projects")
      .select("*")
      .order("created_at", { ascending: false });

    if (error) throw error;

    return data || [];
  } catch (err) {
    console.error("Fetch failed:", err);
    return [];
  }
};

